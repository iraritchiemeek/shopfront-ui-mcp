{
  "name": "rocket-coffee-mcp",
  "version": "1.0.0",
  "description": "MCP server for browsing and ordering from Rocket Coffee",
  "private": true,
  "type": "module",
  "scripts": {
    "build:widgets": "tsx scripts/build-widgets.ts",
    "predev": "pnpm build:widgets",
    "predeploy": "pnpm build:widgets",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:quick": "oxlint -c .oxlintrc.json src/",
    "lint": "oxlint -c .oxlintrc.json src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "knip": "knip",
    "check": "pnpm build:widgets && tsc --noEmit && oxlint -c .oxlintrc.json src/ && prettier --check 'src/**/*.ts'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.5.0",
    "@modelcontextprotocol/sdk": "1.28.0",
    "agents": "^0.8.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "knip": "^6.3.0",
    "oxlint": "^1.58.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "wrangler": "^4.77.0"
  }
}
