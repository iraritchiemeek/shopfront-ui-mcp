{
  "name": "shopfront-ui-mcp",
  "version": "1.0.0",
  "description": "MCP server for browsing and ordering from any Shopify storefront, with interactive widget UI",
  "private": true,
  "type": "module",
  "scripts": {
    "build:widgets": "tsx scripts/build-widgets.ts",
    "build:widgets:watch": "tsx scripts/build-widgets.ts --watch",
    "predev": "pnpm build:widgets",
    "predeploy": "pnpm build:widgets",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:quick": "oxlint -c .oxlintrc.json src/ widgets/",
    "lint": "oxlint -c .oxlintrc.json src/ widgets/",
    "format": "prettier --write 'src/**/*.ts' 'widgets/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.ts' 'widgets/**/*.{ts,tsx,css}'",
    "knip": "knip",
    "check": "pnpm build:widgets && tsc --noEmit && oxlint -c .oxlintrc.json src/ widgets/ && prettier --check 'src/**/*.ts' 'widgets/**/*.{ts,tsx,css}'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@cloudflare/codemode": "^0.3.3",
    "@modelcontextprotocol/ext-apps": "^1.5.0",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "0.8.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "chokidar": "^4.0.0",
    "knip": "^6.3.0",
    "oxlint": "^1.58.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "storybook": "^8.4.7",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.1",
    "wrangler": "^4.77.0"
  }
}
